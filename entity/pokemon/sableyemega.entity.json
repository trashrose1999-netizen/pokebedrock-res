{
	"format_version": "1.18.3",
	"minecraft:client_entity": {
		"description": {
			"identifier": "pokemon:sableyemega",
			"materials": {
				"default": "entity_emissive_alpha",
				"aura": "charged_creeper"
			},
			"textures": {
				"evo_aura": "textures/entity/evolving",
				"default": "textures/entity/pokemon/sableyemega/sableyemega.png",
				"shiny_default": "textures/entity/pokemon/sableyemega/shiny_sableyemega.png",
				"sculk": "textures/entity/pokemon/sableyemega/sableyemega_sculk.png",
				"shiny_sculk": "textures/entity/pokemon/sableyemega/shiny_sableyemega_sculk.png"
			},
			"scripts": {
				"scale": "q.property('pokeb:scale')",
				"initialize": [
					"v.blink_chance = 0.01;",
					"v.move_threshold = 0.01;"
				],
				"pre_animation": [
					"v.skin_index = query.property('pokeb:skin_index');",
					"v.is_ground_idling = query.is_on_ground && query.modified_move_speed < v.move_threshold;",
					"v.is_air_idling = !query.is_on_ground && !query.is_in_water && !query.is_jumping && query.modified_move_speed < v.move_threshold;",
					"v.is_water_idling = query.is_in_water && !query.is_swimming;",
					"v.is_walking = query.modified_move_speed >= v.move_threshold && query.is_on_ground && !query.is_in_water;",
					"v.is_swimming = query.is_swimming;",
					"v.is_flying = query.modified_move_speed >= v.move_threshold && q.can_fly && !query.is_on_ground && !query.is_in_water && !query.is_jumping;",
					"v.is_sleeping = q.is_sleeping;",
					"v.should_blink = math.random(0.0, 1.0) <= v.blink_chance;"
				],
				"animate": [
					"controller",
					{
						"blink": "v.should_blink"
					}
				]
			},
			"animations": {
				"default_blink": "animation.sableyemega.blink",
				"default_ground_idle": "animation.sableyemega.ground_idle",
				"default_air_idle": "animation.sableyemega.ground_idle",
				"default_water_idle": "animation.sableyemega.water_idle",
				"default_walking": "animation.sableyemega.walking",
				"default_flying": "animation.sableyemega.ground_idle",
				"default_swimming": "animation.sableyemega.swimming",
				"default_sleeping": "animation.sableyemega.sleeping",
				"default_attack": "animation.sableyemega.attack",
				"sculk_flying": "animation.sableyemega_sculk.flying",
				"sculk_air_idle": "animation.sableyemega_sculk.air_idle",
				"sculk_swimming": "animation.sableyemega_sculk.swimming",
				"sculk_water_idle": "animation.sableyemega_sculk.water_idle",
				"sculk_walking": "animation.sableyemega_sculk.walking",
				"sculk_ground_idle": "animation.sableyemega_sculk.ground_idle",
				"sculk_sleeping": "animation.sableyemega_sculk.sleeping",
				"sculk_blink": "animation.sableyemega_sculk.blink",
				"sculk_attack": "animation.sableyemega_sculk.attack",
				"sculk_faint": "animation.sableyemega_sculk.faint",
				"look_at_target": "animation.pokemon.look_at_target",
				"attack": "controller.animation.pokemon.sableyemega_attack",
				"blink": "controller.animation.pokemon.sableyemega_blink",
				"controller": "controller.animation.pokemon.sableyemega"
			},
			"render_controllers": [
				{
					"controller.render.pokemon:sableyemega": "query.variant==0"
				},
				{
					"controller.render.pokemon:sableyemega.evolve": "query.variant==1"
				}
			],
			"spawn_egg": {
				"texture": "sableyemega",
				"texture_index": 0
			},
			"geometry": {
				"default": "geometry.sableyemega",
				"sculk": "geometry.sableyemega_sculk"
			}
		}
	}
}
