{
	"format_version": "1.18.3",
	"minecraft:client_entity": {
		"description": {
			"identifier": "pokemon:floetteeternal",
			"materials": {
				"default": "entity_emissive_alpha",
				"aura": "charged_creeper"
			},
			"textures": {
				"evo_aura": "textures/entity/evolving",
				"default": "textures/entity/pokemon/floetteeternal/floetteeternal.png",
				"shiny_default": "textures/entity/pokemon/floetteeternal/shiny_floetteeternal.png",
				"pbranni": "textures/entity/pokemon/floetteeternal/floetteeternal_pbranni.png",
				"shiny_pbranni": "textures/entity/pokemon/floetteeternal/shiny_floetteeternal_pbranni.png"
			},
			"scripts": {
				"scale": "q.property('pokeb:scale')",
				"initialize": [
					"v.blink_chance = 0.01;",
					"v.move_threshold = 0.01;"
				],
				"pre_animation": [
					"v.skin_index = query.property('pokeb:skin_index');",
					"v.is_ground_idling = query.is_on_ground && query.modified_move_speed < v.move_threshold;",
					"v.is_air_idling = !query.is_on_ground && !query.is_in_water && !query.is_jumping && query.modified_move_speed < v.move_threshold;",
					"v.is_water_idling = query.is_in_water && !query.is_swimming;",
					"v.is_walking = query.modified_move_speed >= v.move_threshold && query.is_on_ground && !query.is_in_water;",
					"v.is_swimming = query.is_swimming;",
					"v.is_flying = query.modified_move_speed >= v.move_threshold && q.can_fly && !query.is_on_ground && !query.is_in_water && !query.is_jumping;",
					"v.is_sleeping = q.is_sleeping;",
					"v.should_blink = math.random(0.0, 1.0) <= v.blink_chance;"
				],
				"animate": [
					"controller",
					{
						"blink": "v.should_blink"
					}
				]
			},
			"animations": {
				"default_blink": "animation.floetteeternal.blink",
				"default_ground_idle": "animation.floetteeternal.ground_idle",
				"default_air_idle": "animation.floetteeternal.air_idle",
				"default_water_idle": "animation.floetteeternal.water_idle",
				"default_walking": "animation.floetteeternal.walking",
				"default_flying": "animation.floetteeternal.flying",
				"default_swimming": "animation.floetteeternal.swimming",
				"default_sleeping": "animation.floetteeternal.sleeping",
				"default_attack": "animation.floetteeternal.attack",
				"pbranni_flying": "animation.floetteeternal_pbranni.flying",
				"pbranni_air_idle": "animation.floetteeternal_pbranni.air_idle",
				"pbranni_swimming": "animation.floetteeternal_pbranni.swimming",
				"pbranni_water_idle": "animation.floetteeternal_pbranni.water_idle",
				"pbranni_walking": "animation.floetteeternal_pbranni.walking",
				"pbranni_ground_idle": "animation.floetteeternal_pbranni.ground_idle",
				"pbranni_sleeping": "animation.floetteeternal_pbranni.sleeping",
				"pbranni_blink": "animation.floetteeternal_pbranni.blink",
				"pbranni_attack": "animation.floetteeternal_pbranni.attack",
				"pbranni_faint": "animation.floetteeternal_pbranni.faint",
				"look_at_target": "animation.pokemon.look_at_target",
				"attack": "controller.animation.pokemon.floetteeternal_attack",
				"blink": "controller.animation.pokemon.floetteeternal_blink",
				"controller": "controller.animation.pokemon.floetteeternal"
			},
			"render_controllers": [
				{
					"controller.render.pokemon:floetteeternal": "query.variant==0"
				},
				{
					"controller.render.pokemon:floetteeternal.evolve": "query.variant==1"
				}
			],
			"spawn_egg": {
				"texture": "floetteeternal",
				"texture_index": 0
			},
			"geometry": {
				"default": "geometry.floetteeternal",
				"pbranni": "geometry.floetteeternal_pbranni"
			}
		}
	}
}
